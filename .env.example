# Buy Ghana Lands - Environment Variables Example
# Copy this file to .env and fill in your values

# Database (NeonDB)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# Auth.js
AUTH_SECRET="generate-a-secure-secret-key"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Flutterwave Payment Gateway
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-your_secret_key"
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-your_public_key"
FLUTTERWAVE_SECRET_HASH="your_webhook_secret_hash"

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="your_meilisearch_api_key"

# SMS (mNotify)
MNOTIFY_API_KEY="your_mnotify_api_key"
MNOTIFY_SENDER_ID="BuyGhLands"

# Email (Resend)
RESEND_API_KEY="re_your_resend_api_key"
FROM_EMAIL="noreply@buyghanalands.com"

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN="vercel_blob_token"

# Cloudinary (Image/Video Storage)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Sentry (optional)
SENTRY_DSN=""

# Firebase Cloud Messaging (Push Notifications)
FCM_SERVER_KEY="your_fcm_server_key"

# Apple Sign-In (Required for iOS App Store)
APPLE_CLIENT_ID="com.buyghanalands.app"
APPLE_TEAM_ID="your_apple_team_id"
APPLE_KEY_ID="your_apple_key_id"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_apple_private_key\n-----END PRIVATE KEY-----"
